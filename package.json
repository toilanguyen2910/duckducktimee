{
  "name": "duckducktimee",
  "version": "1.0.0",
  "description": "Desktop Duck Pet - AI CLI companion that quacks when done",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev"
  },
  "devDependencies": {
    "electron": "^28.0.0"
  },
  "build": {
    "appId": "com.duckducktimee.app",
    "productName": "DuckDuckTimee",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!dist",
      "!node_modules"
    ],
    "win": {
      "target": "nsis"
    }
  }
}